# Copy this file to key.properties and fill in your values.
# key.properties is gitignored - never commit it or your keystore.

storePassword=your_keystore_password
keyPassword=your_key_password
keyAlias=upload
# Path relative to android/ folder. Put upload-keystore.jks in android/ or use ../upload-keystore.jks if in project root.
storeFile=upload-keystore.jks
